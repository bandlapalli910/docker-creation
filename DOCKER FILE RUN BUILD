
========================
🐳 DOCKER CHEAT SHEET
========================

# 🔹 Docker Version & Info
docker --version
docker info

# 🔹 Image Commands
docker images
docker build -t image-name .
docker rmi image-name
docker rmi -f image-name
docker pull image-name
docker tag image-name new-name

# 🔹 Container Run
docker run image-name
docker run -it image-name
docker run -it --name cont-name image-name
docker run -d image-name
docker run -p 8080:80 image-name
docker run -it --rm image-name

# 🔹 Container Listing
docker ps
docker ps -a

# 🔹 Container Control
docker stop container-name
docker start container-name
docker restart container-name
docker pause container-name
docker unpause container-name
docker rm container-name
docker rm -f container-name

# 🔹 Execute Inside Container
docker exec -it container-name /bin/bash
docker attach container-name

# 🔹 Logs & Inspect
docker logs container-name
docker inspect container-name
docker top container-name
docker stats

# 🔹 Copy Files
docker cp file.txt container-name:/tmp
docker cp container-name:/tmp/file.txt .

# 🔹 Docker System Cleanup
docker container prune
docker image prune
docker system prune
docker volume prune
docker network prune

# 🔹 Volume Commands
docker volume ls
docker volume create vol-name
docker volume rm vol-name

# 🔹 Network Commands
docker network ls
docker network create net-name
docker network rm net-name

# 🔹 Save & Load Image
docker save -o image.tar image-name
docker load -i image.tar

# 🔹 Export & Import Container
docker export container-name > container.tar
docker import container.tar new-image-name

